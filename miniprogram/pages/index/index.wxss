/* ===== index.wxss - v3 双页面切换模式 ===== */

/* 容器 */
.page-container { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #000; }

/* 两个独立页面，切换 hidden */
.page { position: absolute; top: 0; left: 0; right: 0; bottom: 0; transition: opacity 0.3s ease; }
.page.hidden { display: none; }

.page-dashboard { background: #000; overflow-y: auto; }

/* Muse 风格的光效 */
.page-dashboard::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -20%;
  width: 140%;
  height: 140%;
  opacity: 0.12;
  pointer-events: none;
  background: radial-gradient(ellipse at 30% 20%, rgba(147, 51, 234, 0.4) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 80%, rgba(59, 130, 246, 0.3) 0%, transparent 50%);
}
.page-settings { background: #000; overflow-y: auto; }

.page-settings::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -20%;
  width: 140%;
  height: 140%;
  opacity: 0.1;
  pointer-events: none;
  background: radial-gradient(ellipse at 50% 30%, rgba(147, 51, 234, 0.3) 0%, transparent 50%);
}

/* 可滚动内容区 */
.page-scroll { height: 100%; overflow-y: auto; display: flex; flex-direction: column; }

/* --- 顶部 --- */
.top-bar { display: flex; justify-content: space-between; align-items: flex-start; padding: 140rpx 40rpx 0; }
.car-name { font-size: 40rpx; font-weight: 500; color: #fff; line-height: 1.2; }
.status-row { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #00d084; box-shadow: 0 0 12rpx #00d084; }
.status-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }

/* --- 续航 --- */
.range-area { display: flex; flex-direction: column; align-items: center; margin-top: 60rpx; }
.range-num { font-size: 80rpx; font-weight: 500; color: #fff; line-height: 1; }
.battery-row { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }
.battery-text { font-size: 28rpx; color: rgba(255,255,255,0.5); letter-spacing: 2rpx; }

/* --- 车辆图片 --- */
.car-img-wrap { width: 100%; height: 460rpx; display: flex; align-items: center; justify-content: center; margin-top: 20rpx; }
.car-img { width: 90%; }

/* --- 位置卡片 --- */
.location-card { display: flex; align-items: center; gap: 32rpx; background: rgba(255,255,255,0.06); border-radius: 32rpx; padding: 40rpx; margin: 0 40rpx 40rpx; border: 1rpx solid rgba(255,255,255,0.1); }
.loc-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.loc-texts { display: flex; flex-direction: column; }
.loc-title { font-size: 28rpx; font-weight: 500; color: #fff; }
.loc-addr { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }

/* ===== 控制面板 ===== */
.ctrl-panel { background: #1c1c1e; border-radius: 60rpx 60rpx 0 0; border-top: 1rpx solid rgba(255,255,255,0.05); margin-top: auto; max-height: 440rpx; transition: max-height 0.35s ease; overflow: hidden; position: relative; z-index: 10; }
.ctrl-panel.expanded { max-height: 8000rpx; height: auto; }

/* 展开时覆盖全屏 */
.page-dashboard.expand-active { overflow: hidden; }
.page-dashboard.expand-active .ctrl-panel { position: fixed; left: 0; right: 0; bottom: 0; border-radius: 60rpx 60rpx 0 0; max-height: 90vh; overflow-y: auto; }

.panel-handle { width: 100%; height: 80rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.handle-bar { width: 80rpx; height: 8rpx; background: rgba(255,255,255,0.2); border-radius: 4rpx; }
.panel-body { padding: 0 40rpx 60rpx; }
.panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.panel-title { font-size: 32rpx; font-weight: 500; color: #fff; }
.panel-fold { font-size: 24rpx; color: #60a5fa; }

.grid-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.ctrl-btn { height: 180rpx; border-radius: 32rpx; display: flex; align-items: center; padding: 0 32rpx; gap: 24rpx; }
.ctrl-btn:active { opacity: 0.8; }
.ctrl-btn.off { background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.1); }
.ctrl-btn.on { background: #fff; }
.icon-circle { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(255,255,255,0.1); }
.icon-circle.icon-on { background: rgba(0,0,0,0.05); }
.ctrl-label { font-size: 28rpx; font-weight: 500; }
.ctrl-btn.off .ctrl-label { color: #fff; }
.ctrl-btn.on .ctrl-label { color: #000; }

.collapsed { display: flex; flex-direction: column; gap: 24rpx; }
.row-2btns { display: flex; gap: 24rpx; }
.main-btn { flex: 1; }
.scroll-x { display: flex; flex-direction: row; overflow-x: auto; white-space: nowrap; padding-bottom: 20rpx; }
.x-btn { display: inline-flex; flex-direction: column; align-items: center; justify-content: center; width: 240rpx; height: 160rpx; background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 32rpx; margin-right: 24rpx; gap: 12rpx; flex-shrink: 0; }
.x-btn:active { opacity: 0.8; }
.x-btn.on { background: #fff; }
.x-label { font-size: 24rpx; font-weight: 500; }
.x-btn.off .x-label { color: #fff; }
.x-btn.on .x-label { color: #000; }

/* ===== 设置页 ===== */
.set-header { padding: 140rpx 40rpx 0; display: flex; justify-content: center; }
.set-header-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; }
.set-back { width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; }
.set-title { font-size: 32rpx; font-weight: 500; color: #fff; }
.set-body { padding: 0 40rpx; margin-top: 40rpx; flex: 1; }

.set-card { background: #1c1c1e; border-radius: 48rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.1); }
.set-card-head { padding: 48rpx 48rpx 20rpx; }
.set-card-title { font-size: 34rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 12rpx; }
.set-card-desc { font-size: 24rpx; color: rgba(255,255,255,0.5); line-height: 1.5; }
.set-card-body { padding: 40rpx 48rpx; }
.set-card-foot { padding: 0 48rpx 48rpx; display: flex; align-items: center; gap: 12rpx; justify-content: center; }

.bound-card { background: #2c2c2e; border-radius: 32rpx; padding: 40rpx; display: flex; align-items: center; gap: 24rpx; border: 1rpx solid rgba(255,255,255,0.1); margin-bottom: 40rpx; }
.bound-avatar { width: 80rpx; height: 80rpx; background: rgba(0,208,132,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.bound-email { font-size: 28rpx; font-weight: 500; color: #fff; display: block; margin-bottom: 4rpx; }
.bound-sync { font-size: 22rpx; color: #00d084; display: flex; align-items: center; gap: 8rpx; }
.d-green { width: 8rpx; height: 8rpx; background: #00d084; border-radius: 50%; }

.btn-unbind { width: 100%; padding: 32rpx; border-radius: 24rpx; font-size: 30rpx; font-weight: 600; text-align: center; background: rgba(232,33,39,0.1); color: #e82127; border: 1rpx solid rgba(232,33,39,0.2); }

/* OAuth 授权按钮 */
.oauth-intro { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 40rpx; }
.oauth-intro-text { font-size: 24rpx; color: rgba(255,255,255,0.5); line-height: 1.5; flex: 1; }

.btn-oauth { width: 100%; padding: 32rpx; border-radius: 24rpx; font-size: 30rpx; font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; gap: 16rpx; background: #1c1c1e; color: #fff; border: 1rpx solid rgba(232,33,39,0.4); margin-bottom: 32rpx; }
.btn-oauth:active { background: #2c2c2e; }

.oauth-tips { display: flex; flex-direction: column; gap: 12rpx; }
.tip-item { font-size: 22rpx; color: rgba(255,255,255,0.35); line-height: 1.4; }

.btn-refresh { width: 100%; padding: 32rpx; border-radius: 24rpx; font-size: 28rpx; font-weight: 500; text-align: center; color: #60a5fa; background: rgba(96,165,250,0.08); border: 1rpx solid rgba(96,165,250,0.15); margin-bottom: 24rpx; }

.d-blue { width: 12rpx; height: 12rpx; background: #3e63dd; border-radius: 50%; }
.foot-tip { font-size: 22rpx; color: rgba(255,255,255,0.5); }

.toast-float { position: fixed; bottom: 280rpx; left: 50%; transform: translateX(-50%); background: #00d084; color: #fff; padding: 20rpx 40rpx; border-radius: 999rpx; font-size: 24rpx; z-index: 50; }

::-webkit-scrollbar { width: 0; height: 0; display: none; }

/* --- 充电状态 --- */
.charging-badge { display: inline-block; font-size: 20rpx; background: rgba(0,208,132,0.2); color: #00d084; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 500; }
.charged-badge { display: inline-block; font-size: 20rpx; background: rgba(96,165,250,0.2); color: #60a5fa; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 500; }

/* --- 温度信息 --- */
.temp-row { display: flex; align-items: center; gap: 4rpx; margin-top: 12rpx; }
.temp-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }

/* --- 充电详细信息 --- */
.charge-info { margin-top: 8rpx; }
.charge-info-text { font-size: 22rpx; color: #00d084; }

/* --- 离线/休眠状态 --- */
.status-dot.offline { background: rgba(255,255,255,0.2); box-shadow: none; }
/* --- 唤醒按钮 --- */
.wake-btn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 6rpx 20rpx; border-radius: 16rpx; margin-left: 10rpx;
  background: rgba(96,165,250,0.15); border: 1rpx solid rgba(96,165,250,0.3);
  cursor: pointer;
}
.wake-btn-text { font-size: 22rpx; color: #60a5fa; font-weight: 500; }
.wake-btn:active { background: rgba(96,165,250,0.3); }
/* --- 唤醒中指示器 --- */
.waking-indicator {
  display: inline-flex; align-items: center; gap: 10rpx; margin-left: 10rpx;
}
.waking-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.waking-spinner {
  display: inline-block; width: 32rpx; height: 32rpx; vertical-align: middle;
  border: 3rpx solid rgba(255,255,255,0.15);
  border-top-color: rgba(255,255,255,0.6);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.status-row.clickable { cursor: pointer; }

/* ===== 方案1：OAuth tab 切换 & 密码表单 ===== */
.oauth-tabs {
  display: flex;
  flex-direction: row;
  gap: 0;
  margin-bottom: 32rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 24rpx;
  padding: 6rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}
.tab-item.active {
  background: rgba(232,33,39,0.2);
  color: #e82127;
  font-weight: 600;
}

.password-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.form-field {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.4;
}
.form-placeholder {
  color: rgba(255,255,255,0.3);
}
