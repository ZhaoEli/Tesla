/**index.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #ffffff;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 80rpx;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
}

.car-status {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 40rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.online {
  background: #00d084;
  box-shadow: 0 0 12rpx #00d084;
}

.status-dot.offline {
  background: #ff6b6b;
}

.status-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.control-area {
  margin-bottom: 80rpx;
}

.lock-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.lock-btn.locked {
  background: rgba(255, 255, 255, 0.1);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.lock-btn.unlocked {
  background: rgba(0, 208, 132, 0.2);
  border: 4rpx solid #00d084;
  box-shadow: 0 0 40rpx rgba(0, 208, 132, 0.3);
}

.lock-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.lock-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.action-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 60rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  width: 140rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-area {
  margin-top: auto;
}

.login-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}