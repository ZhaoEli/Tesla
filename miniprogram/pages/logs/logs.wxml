<!--logs.wxml-->
<view class="container">
  <van-notify id="van-notify" />

  <!-- 顶部操作栏 -->
  <view class="toolbar" wx:if="{{logs.length > 0}}">
    <text class="toolbar-title">共 {{logs.length}} 条记录</text>
    <van-button size="small" type="danger" plain custom-class="clear-btn" bindtap="onClearLogs">
      清除
    </van-button>
  </view>

  <!-- 日志列表 -->
  <view class="log-list" wx:if="{{logs.length > 0}}">
    <view class="card log-card" wx:for="{{logs}}" wx:key="timeStamp">
      <van-cell
        title="{{item.date}}"
        label="操作记录"
        border="{{false}}"
        custom-class="log-cell"
        value-class="log-index"
        value="#{{index + 1}}"
      />
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{logs.length === 0}}">
    <van-icon name="orders-o" size="80px" color="rgba(255,255,255,0.15)" />
    <text class="empty-text">暂无操作日志</text>
    <text class="empty-hint">进行车辆操作后日志将自动记录在此</text>
  </view>
</view>