/**logs.wxss**/
.container {
  padding: 20rpx 0;
}

.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.toolbar-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.clear-btn {
  --button-danger-background-color: transparent !important;
  --button-danger-border-color: var(--tesla-red) !important;
  --button-danger-color: var(--tesla-red) !important;
}

.log-list {
  padding: 0 16rpx;
}

.log-card {
  margin: 8rpx 16rpx;
  padding: 0;
  border-radius: 16rpx;
}

.log-cell {
  background: transparent !important;
  color: #ffffff !important;
}

.log-index {
  color: rgba(255, 255, 255, 0.3) !important;
  font-size: 24rpx !important;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 32rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-top: 12rpx;
}