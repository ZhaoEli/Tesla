/**logs.wxss**/
.log-list {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
}

.log-item {
  margin: 10rpx 0;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  margin-top: 200rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
}