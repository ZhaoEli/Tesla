# ============================================
# 环境配置示例文件
# 复制此文件为 .env 或直接填写 cloud/config.js
# 此文件可安全提交到版本控制
# ============================================

# 微信小程序配置
WX_APPID=wx8919a7c332ae50eb
WX_APP_SECRET=你的微信AppSecret

# Tesla Fleet API 配置
TESLA_CLIENT_ID=你的Tesla_Client_ID
TESLA_CLIENT_SECRET=你的Tesla_Client_Secret
TESLA_AUDIENCE=https://fleet-api.prd.na.tesla.com
TESLA_PUBLIC_KEY_HOST=https://your-domain.com

# 微信云开发环境 ID（开通云开发后填写）
CLOUD_ENV_ID=你的云环境ID